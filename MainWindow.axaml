<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="study_hub_reservation_system.MainWindow"
        Title="JIT Study Hub Reservation System"
        WindowState="Maximized"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        Background="#F5F5F7">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="FontSize" Value="19" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D2D2D7" />
        </Style>
        <Style Selector="TextBlock.heading">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="Foreground" Value="#111111" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,4" />
            <Setter Property="Foreground" Value="#3A3A3C" />
            <Setter Property="FontSize" Value="19" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0A84FF" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F2F2F7" />
            <Setter Property="BorderBrush" Value="#D2D2D7" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C7C7CC" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="17" />
        </Style>
        <Style Selector="Border#AuthPanel TextBox">
            <Setter Property="Width" Value="320" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C7C7CC" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="17" />
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C7C7CC" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="17" />
        </Style>
        <Style Selector="TabStrip">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="TabStrip /template/ ItemsPresenter">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TabItem /template/ ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Classes="card" CornerRadius="14" BorderThickness="1" Padding="14" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Image Width="44"
                       Height="44"
                       VerticalAlignment="Center"
                      Source="avares://study_hub_reservation_system/Assets/logo.jpg" />

                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="JIT Study Hub and Coworking Space"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="Reservation System"
                               FontSize="18"
                               Foreground="#6E6E73" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid ColumnDefinitions="15*,70*,15*" VerticalAlignment="Center">
                <Border Name="AuthPanel"
                        Grid.Column="1"
                        Classes="card"
                        MinHeight="520"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        BorderThickness="1"
                        CornerRadius="12"
                        ClipToBounds="True">
                    <Grid ColumnDefinitions="1.1*,1*">
                    <Grid Grid.Column="0">
                           <Image Source="avares://study_hub_reservation_system/Assets/login-image.png"
                               Stretch="UniformToFill" />
                        <Border Background="#66000000" />
                        <StackPanel VerticalAlignment="Bottom" Margin="24" Spacing="6">
                            <TextBlock Text="JIT Study Hub"
                                       Foreground="White"
                                       FontSize="38"
                                       FontWeight="Bold" />
                            <TextBlock Text="Reserve your ideal workspace in seconds."
                                       Foreground="#F2F2F7"
                                       FontSize="18"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="1" Padding="24" Background="#FFFFFF">
                        <StackPanel Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Reserve your Seat Here" Classes="heading" HorizontalAlignment="Center" />
                            <TextBlock Text="Do you want a perfect place to make you more focus and locked in? You found it!"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       Opacity="0.8"
                                       Margin="20,0,20,12" />

                            <TabControl HorizontalAlignment="Center" Width="360">
                                <TabItem Header="Log In">
                                    <StackPanel Margin="0,12,0,0" Spacing="6">
                                        <TextBlock Text="Username" Classes="label" />
                                        <TextBox Name="LoginUsernameTextBox" Watermark="Enter username" />

                                        <TextBlock Text="Password" Classes="label" />
                                        <TextBox Name="LoginPasswordTextBox" PasswordChar="*" Watermark="Enter password" />

                                        <Button Content="Log In"
                                            Classes="primary"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            Click="LoginButton_Click" />

                                        <TextBlock Name="LoginMessageTextBlock"
                                                   Margin="0,10,0,0"
                                                   Foreground="#FF3B30"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Sign Up">
                                    <StackPanel Margin="0,12,0,0" Spacing="6">
                                        <TextBlock Text="Username" Classes="label" />
                                        <TextBox Name="SignupUsernameTextBox" Watermark="Choose username" />

                                        <TextBlock Text="Email Address" Classes="label" />
                                        <TextBox Name="SignupEmailTextBox" Watermark="Enter your email" />

                                        <TextBlock Text="Password" Classes="label" />
                                        <TextBox Name="SignupPasswordTextBox" PasswordChar="*" Watermark="Choose password" />

                                        <TextBlock Text="Confirm Password" Classes="label" />
                                        <TextBox Name="SignupConfirmPasswordTextBox" PasswordChar="*" Watermark="Confirm password" />

                                        <Button Content="Create Account"
                                            Classes="primary"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            Click="SignupButton_Click" />

                                        <TextBlock Name="SignupMessageTextBlock"
                                                   Margin="0,10,0,0"
                                                   Foreground="#FF3B30"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Name="BookingPanel" IsVisible="False" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Classes="card" Padding="12" CornerRadius="10" BorderThickness="1" Margin="0,0,0,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Name="WelcomeTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Button Grid.Column="1" Content="Log Out" Classes="secondary" Click="LogoutButton_Click" Foreground="White" Background="#800000"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="1.9*,0.75*" ColumnSpacing="14">
                    <Border Grid.Column="0" Classes="card" Padding="14" CornerRadius="10" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Seat Plan" Classes="heading" />
                            <TextBlock Text="Click a seat to select it. Light gray seats are available, darker gray seats are reserved, and blue is your current selection."
                                       Margin="0,4,0,12"
                                       TextWrapping="Wrap" />

                            <Border Background="#FBFBFD"
                                    BorderBrush="#D2D2D7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,8,0,8">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                                                                            Height="560">
                                    <Canvas Name="SeatCanvas"
                                                                                        Width="1700"
                                                                                        Height="860"
                                            Background="#FBFBFD" />
                                </ScrollViewer>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="16" Height="16" Background="#E5E5EA" BorderBrush="#C7C7CC" BorderThickness="1" CornerRadius="3" />
                                    <TextBlock Text="Available" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="16" Height="16" Background="#B0B0B7" CornerRadius="3" />
                                    <TextBlock Text="Reserved" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="16" Height="16" Background="#0A84FF" CornerRadius="3" />
                                    <TextBlock Text="Selected" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card" Padding="14" CornerRadius="10" BorderThickness="1">
                        <ScrollViewer>
                            <StackPanel Spacing="8">
                                <TextBlock Text="Reservation Information" Classes="heading" />

                                <TextBlock Text="Selected Seats" Classes="label" />
                                <TextBlock Name="SelectedSeatTextBlock" Text="None" />

                                <TextBlock Text="Reservation Date" Classes="label" />
                                <DatePicker Name="ReservationDatePicker"
                                            SelectedDateChanged="ReservationDatePicker_SelectedDateChanged" />

                                <TextBlock Text="Start Time" Classes="label" />
                                <ComboBox Name="StartHourComboBox"
                                          SelectionChanged="ReservationInputs_SelectionChanged" />

                                <TextBlock Text="End Time" Classes="label" />
                                <ComboBox Name="EndHourComboBox"
                                          SelectionChanged="ReservationInputs_SelectionChanged" />

                                <TextBlock Text="Seat Rate" Classes="label" />
                                <TextBlock Name="SeatRateTextBlock" />

                                <TextBlock Text="Cost Summary" Classes="label" />
                                <TextBlock Name="CostSummaryTextBlock" TextWrapping="Wrap" />

                                <TextBlock Text="Status" Classes="label" />
                                <TextBlock Name="SeatStatusTextBlock"
                                       Foreground="#FF3B30"
                                           TextWrapping="Wrap" />

                                <Button Content="Reserve Selected Seats"
                                    Classes="primary"
                                        Margin="0,8,0,0"
                                        Click="ReserveButton_Click" />

                                <TextBlock Text="Reserved Seats for Selected Date" Classes="label" Margin="0,16,0,6" />
                                <ListBox Name="ReservationsListBox" Height="220" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
